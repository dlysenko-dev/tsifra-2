# Digital Clone v3 — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git

# ============================================
# LLM Providers (at least one required)
# ============================================
KIMI_API_KEY=sk-your-kimi-key-here
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
GROQ_API_KEY=gsk-your-groq-key-here
GLM_API_KEY=your-glm-key-here

# OpenRouter (optional — provides 200+ models)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Local LLM (Ollama)
OLLAMA_HOST=http://localhost:11434

# ============================================
# Telegram Bot
# ============================================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-BotFather

# Default channel for autonomous posts
AUTONOMOUS_CHAT_ID=@your_channel_username

# ============================================
# Optional: Other Services
# ============================================
# ElevenLabs (text-to-speech)
ELEVENLABS_API_KEY=your-elevenlabs-key

# ComfyUI / Stable Diffusion (image generation)
COMFYUI_URL=http://localhost:8188

# ============================================
# Application Settings
# ============================================
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Autonomy level: 1=manual, 2=assisted, 3=autonomous
DEFAULT_AUTONOMY_LEVEL=2

# Quality threshold (0.0 - 1.0)
QUALITY_THRESHOLD=0.7
